# Copy to .env and fill in for live-provider runs.
# All deterministic tests MUST pass without this key (fake providers are used in CI).
GEMINI_API_KEY=

# Safe default is fully offline. Set to gemini for a configured live smoke.
EPISTEMICOS_PROVIDER_MODE=fake
EPISTEMICOS_SEED_DEMO=0

# Optional runtime/model overrides
EPISTEMICOS_DB_PATH=epistemicos.db
EPISTEMICOS_FAST_MODEL=gemini-3.1-flash-lite
EPISTEMICOS_ESCALATION_MODEL=gemini-3.5-flash
EPISTEMICOS_EMBED_MODEL=gemini-embedding-001
