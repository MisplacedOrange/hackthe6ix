# Local configuration template for the sacrificial canary model.
#
# Copy this to starter/.env (next to my_solution.py); it is git-ignored and
# auto-loaded by _load_local_dotenv(). The scored deterministic path never
# requires this file: with no key present, the canary stays inert and ingest
# behaves identically to a pure deterministic policy.
#
# These are the ONLY variables the policy reads. Anything else is ignored.

# off | shadow | fallback
#   off      = canary never called (pure deterministic policy)
#   shadow   = canary is called and measured, but can never change the output
#   fallback = canary influences UNSURE (firewall-flagged) items after its
#              verdict is re-verified by the deterministic policy
GT_LLM_MODE=fallback

# Google AI Studio API key (keys usually start with "AIza"). Never commit it.
GEMINI_API_KEY=

# Sacrificial model. Pin a current, low-cost lite model. Note: some older IDs
# (e.g. gemini-2.5-flash-lite) are no longer available to new API keys and
# return 404. gemini-3.1-flash-lite is a current, working choice.
GT_GEMINI_MODEL=gemini-3.1-flash-lite

# Bounded per-request controls. The Gemini API enforces a 10s minimum request
# deadline; values below 10 are floored to 10 by the client. Invalid values
# resolve to safe defaults.
GT_LLM_TIMEOUT_SECONDS=15.0
GT_LLM_MAX_OUTPUT_TOKENS=512
