# Local configuration template for the planned sacrificial Gemini oracle.
# Copy this file to .env for local tooling, keep .env uncommitted, and load the
# values through your shell/IDE. The scored deterministic path must not require
# this file or a dotenv dependency.

# off | shadow | fallback
# Safe default: Gemini is never called and the current deterministic policy is
# authoritative.
GT_LLM_MODE=off

# Add a local key only in starter/.env; never commit credentials.
GEMINI_API_KEY=

# Pin exact model IDs for reproducible evaluations. The first model is the
# low-cost sacrificial oracle; the comparator is used only by the evaluation
# runner, never for runtime voting.
GT_GEMINI_MODEL=gemini-2.5-flash-lite
GT_GEMINI_COMPARATOR_MODEL=gemini-2.5-flash

# Bounded runtime controls. Invalid values must resolve to safe defaults/off.
GT_LLM_TIMEOUT_SECONDS=3.0
GT_LLM_MAX_RETRIES=0
GT_LLM_MAX_OUTPUT_TOKENS=512
GT_LLM_TEMPERATURE=0

# Include both values in cache keys and redacted experiment records.
GT_LLM_PROMPT_VERSION=sacrificial-witness-v1
GT_LLM_SCHEMA_VERSION=1

# Caching is optional and stores validated witness JSON only. Raw evidence-body
# logging is disabled by default.
GT_LLM_CACHE_ENABLED=false
GT_LLM_CACHE_DIR=.cache/ground-truth-llm
GT_LLM_LOG_RAW_BODIES=false

# Networked adversarial evaluation only; not read by the scored entrypoint.
GT_LLM_EVAL_REPEATS=5
